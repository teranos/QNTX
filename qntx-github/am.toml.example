# Example configuration for qntx-github plugin
# Copy this to your am.toml and configure as needed

[github]
# GitHub personal access token for API authentication
# Create at: https://github.com/settings/tokens
# Scopes needed: repo (for repository events)
token = "ghp_..."

# List of repositories to watch for events
# Format: owner/repo
repos = [
  "teranos/qntx",
  # Add more repos here
]

# Poll interval in seconds (default: 300 = 5 minutes)
# GitHub API rate limit: 5,000 requests/hour with token
# Recommended: 60-900 seconds (1-15 minutes)
poll_interval = 300
