{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "baseUrl": "..",
    "paths": {
      "@qntx/glyphs": ["packages/glyphs/index.ts"]
    }
  },
  "include": ["web/**/*.ts"]
}
