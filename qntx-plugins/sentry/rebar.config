{erl_opts, [debug_info, warnings_as_errors]}.

{escript_incl_apps, [sentry]}.
{escript_main_app, sentry}.
{escript_name, "qntx-sentry-plugin"}.
{escript_emu_args, "%%!\n"}.

%% No external deps — raw HTTP/2, raw protobuf, raw HPACK.
%% Erlang's binary pattern matching makes protocol codecs trivial.
{deps, []}.
